    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "x-cost-access-token", "value": "{{cost_access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/products?search=&status=all&hasBarcode=all&pricingChannel=retail&page=1&pageSize=8",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "search", "value": "" },
                { "key": "status", "value": "all" },
                { "key": "hasBarcode", "value": "all" },
                { "key": "pricingChannel", "value": "retail" },
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "8" }
              ]
            }
          }
        },
        {
          "name": "Get Product Detail",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "x-cost-access-token", "value": "{{cost_access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}?pricingChannel=retail",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"],
              "query": [{ "key": "pricingChannel", "value": "retail" }]
            }
          }
        },
        {
          "name": "Create Product (sets product_id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.id) {",
                  "  pm.environment.set('product_id', String(json.id));",
                  "  pm.collectionVariables.set('product_id', String(json.id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "x-cost-access-token", "value": "{{cost_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laser Cutter X1\",\n  \"sku\": \"SKU-LASER-X1-{{timestamp}}\",\n  \"productCode\": \"PRD-LASER-X1-{{timestamp}}\",\n  \"barcode\": \"690000000001{{timestamp}}\",\n  \"images\": [],\n  \"description\": \"Machine overview\",\n  \"usageGuide\": \"How to use\",\n  \"pros\": \"Stable output\",\n  \"cons\": \"Need warm-up\",\n  \"categoryId\": 1,\n  \"unit\": \"pcs\",\n  \"costPrice\": 1000,\n  \"sellingPrice\": 1600,\n  \"pricingRules\": [\n    {\n      \"ruleName\": \"Retail\",\n      \"channelKey\": \"retail\",\n      \"markupPercentage\": 30,\n      \"isDefault\": true,\n      \"sortOrder\": 0\n    },\n    {\n      \"ruleName\": \"Wholesale\",\n      \"channelKey\": \"wholesale\",\n      \"markupPercentage\": 15,\n      \"isDefault\": false,\n      \"sortOrder\": 1\n    }\n  ],\n  \"reorderLevel\": 5,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "x-cost-access-token", "value": "{{cost_access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laser Cutter X1 (Updated)\",\n  \"sku\": \"SKU-LASER-X1-UPDATED\",\n  \"productCode\": \"PRD-LASER-X1\",\n  \"barcode\": \"690000000001\",\n  \"images\": [],\n  \"description\": \"Updated overview\",\n  \"usageGuide\": \"Updated guide\",\n  \"pros\": \"Updated pros\",\n  \"cons\": \"Updated cons\",\n  \"categoryId\": 1,\n  \"unit\": \"pcs\",\n  \"costPrice\": 1000,\n  \"sellingPrice\": 1700,\n  \"pricingRules\": [\n    {\n      \"ruleName\": \"Retail\",\n      \"channelKey\": \"retail\",\n      \"markupPercentage\": 35,\n      \"isDefault\": true,\n      \"sortOrder\": 0\n    }\n  ],\n  \"reorderLevel\": 6,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            }
          }
        }
